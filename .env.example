# Public browser configuration
# Copy to .env.local for local development. Never commit .env.local.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Optional free-tier browser error monitoring.
# Create a Sentry browser project and add the DSN in Vercel and local .env.local.
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_RELEASE=

# Optional sampling. Keep low in production to preserve free-tier quota.
VITE_SENTRY_TRACES_SAMPLE_RATE=0
